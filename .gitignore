# ─────────────────────────────────────────────
# StoryVaultOS — .gitignore
# ─────────────────────────────────────────────

# User vault: contains your API key, projects, and all story data.
# This is intentionally excluded from source control.
StoryVault/

# Environment secrets — copy .env.example to .env to configure
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.installed.cfg
*.egg
.eggs/
MANIFEST

# ── Virtual environments ──────────────────────
.venv/
venv/
env/
ENV/

# ── Testing / coverage ────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE / editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ─────────────────────────────────────
*.log
flask.log

# ── Claude Code ───────────────────────────────
.claude/

# ── Windows artefacts ─────────────────────────
nul
