# ─────────────────────────────────────────────────────────────────
# StoryVaultOS — Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# StoryVaultOS will load it automatically on startup.
#
#   cp .env.example .env          (Linux / macOS)
#   copy .env.example .env        (Windows)
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────
# Override the default model (default: gpt-4o-mini)
# Any OpenAI model identifier works — gpt-4o is higher quality but costs more.
# STORYVAULT_MODEL=gpt-4o-mini

# Flask development server port (default: 5000)
# FLASK_PORT=5000
